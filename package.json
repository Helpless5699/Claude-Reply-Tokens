{
  "name": "claude-reply-tokens",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "icon": "icon.png",
  "version": "0.2.1",
  "publisher": "helpless5699",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Helpless5699/Claude-Reply-Tokens.git"
  },
  "homepage": "https://github.com/Helpless5699/Claude-Reply-Tokens",
  "bugs": {
    "url": "https://github.com/Helpless5699/Claude-Reply-Tokens/issues"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "claudeReplyTokens.refresh",
        "title": "%command.refresh.title%",
        "category": "%command.category%"
      },
      {
        "command": "claudeReplyTokens.openTurnAnalysis",
        "title": "%command.openTurnAnalysis.title%",
        "category": "%command.category%"
      },
      {
        "command": "claudeReplyTokens.openTranscript",
        "title": "%command.openTranscript.title%",
        "category": "%command.category%"
      },
      {
        "command": "claudeReplyTokens.openSettings",
        "title": "%command.openSettings.title%",
        "category": "%command.category%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "claudeReplyTokens.dataDirectory": {
          "type": "string",
          "default": "",
          "description": "%configuration.dataDirectory.description%"
        },
        "claudeReplyTokens.refreshIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 30,
          "description": "%configuration.refreshIntervalSeconds.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node --test out/test/sessionTracker.test.js",
    "prepackage:vsix": "npm run compile",
    "package:vsix": "vsce package",
    "prepublish:vsce": "npm run compile",
    "publish:vsce": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.86.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.6.3"
  }
}
